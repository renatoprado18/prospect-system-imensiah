{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/health-recalc",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/editorial-metrics-reminder-evening",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/group-digest",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/platform-costs-snapshot",
      "schedule": "0 12 2 * *"
    },
    {
      "path": "/api/cron/circulos-recalc",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/wa-backfill-1to1",
      "schedule": "30 9 * * *"
    }
  ]
}
