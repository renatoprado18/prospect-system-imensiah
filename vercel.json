{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/daily-sync",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/health-recalc",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/sync-whatsapp-history",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/editorial-weekly-briefing",
      "schedule": "0 21 * * 0"
    },
    {
      "path": "/api/cron/index-drive-documents",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sync-conselhoos-raci",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-morning-briefing",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/daily-evening-debriefing",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/editorial-metrics-reminder",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/editorial-metrics-reminder-evening",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/pre-meeting-briefings",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/group-digest",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/email-digest",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/raci-weekly-report",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/daily-synthesis",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/auto-publish-linkedin",
      "schedule": "5 12 * * *"
    },
    {
      "path": "/api/cron/auto-collect-linkedin-metrics",
      "schedule": "0 13 * * *"
    }
  ]
}
