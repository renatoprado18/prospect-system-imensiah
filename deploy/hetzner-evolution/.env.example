# Copie para .env no VPS antes de subir o compose. NAO commitar .env.
# Gere senhas com: openssl rand -hex 24

# Dominio publico (DNS A record apontando pro IP do VPS)
DOMAIN=wa.almeida-prado.com
SERVER_URL=https://wa.almeida-prado.com

# Postgres (interno, so containers acessam — escolha uma senha forte)
POSTGRES_PASSWORD=trocar_por_openssl_rand_hex_24

# API key Evolution — pode reusar a mesma do Railway pra evitar mudanca no Vercel
# (recomendado: REUTILIZAR a atual, ai so muda EVOLUTION_API_URL no Vercel)
EVOLUTION_API_KEY=c79c7502cc300533229bf73e68b8d86d4ae98e13c3b6c31a91869b3b1f878c62

# Webhook global (apontar pro INTEL em prod)
WEBHOOK_GLOBAL_URL=https://intel.almeida-prado.com/api/webhooks/whatsapp
