# ============================================
# INTEL - Configuração de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# -----------------------------
# Ambiente (development/production)
# -----------------------------
APP_ENV=development

# Para desenvolvimento local, use:
BASE_URL=http://localhost:8000

# Para produção (Vercel):
# BASE_URL=https://intel.almeida-prado.com

# -----------------------------
# Banco de Dados (PostgreSQL)
# -----------------------------
DATABASE_URL=postgresql://user:password@host:5432/database

# -----------------------------
# Google OAuth & APIs
# -----------------------------
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALENDAR_ID=primary

# IMPORTANTE: Adicione estas URIs de redirecionamento no Google Cloud Console:
#
# Para desenvolvimento local:
#   http://localhost:8000/auth/google/callback
#   http://localhost:8000/api/google/callback
#   http://localhost:8000/api/gmail/callback
#
# Para produção:
#   https://intel.almeida-prado.com/auth/google/callback
#   https://intel.almeida-prado.com/api/google/callback
#   https://intel.almeida-prado.com/api/gmail/callback

# -----------------------------
# Segurança
# -----------------------------
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# -----------------------------
# Integrações (Opcionais)
# -----------------------------
# Fathom (transcrição de reuniões)
FATHOM_API_KEY=your_fathom_api_key
FATHOM_API_KEY_PROFISSIONAL=your_fathom_api_key_profissional
FATHOM_API_KEY_PESSOAL=your_fathom_api_key_pessoal
# Secrets retornados por POST /webhooks (ver scripts/register_fathom_webhook.py)
FATHOM_WEBHOOK_SECRET_PROFISSIONAL=whsec_xxx
FATHOM_WEBHOOK_SECRET_PESSOAL=whsec_xxx

# Claude AI (análise de conteúdo)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Voyage AI (embeddings — Fase 6 Life Coaching, busca semantica em system_memories)
# Obter em: https://dashboard.voyageai.com/organization/api-keys
# Modelo usado: voyage-4-lite ($0.02/1M tokens, multilingual). Free tier: 200M tokens.
# Sem essa chave, search_system_memories degrada graciosamente pra keyword-only.
VOYAGE_API_KEY=your_voyage_api_key

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# LinkedIn (LinkdAPI - enriquecimento + metricas editorial)
LINKDAPI_KEY=your_linkdapi_key
# Username do perfil LinkedIn dono dos posts (slug em /in/<username>)
# Usado por editorial_metrics_collector pra puxar metricas via LinkdAPI
LINKEDIN_USERNAME=your_linkedin_username

# -----------------------------
# LinkedIn Comment Curator (P1 MVP)
# -----------------------------
# Cron diario 7h BRT (vercel.json: 0 10 * * * UTC) analisa tasks "LinkedIn:
# Curtir post de X" via Sonnet scoring + Opus drafts (so se score >= threshold).
# Estima ~$11-17/mes em regime estavel (10 analises/dia, 3 com drafts).

# Score minimo pra disparar Opus (gera drafts A/B/DM)
LINKEDIN_CURATOR_SCORE_THRESHOLD=7

# Modelos usados (hibrido Sonnet rapido + Opus quality)
LINKEDIN_CURATOR_MODEL_SCORING=claude-sonnet-4-6
LINKEDIN_CURATOR_MODEL_DRAFT=claude-opus-4-7

# Cap diario de analises (controle de custo)
LINKEDIN_CURATOR_MAX_DAILY=15
